# ─── ASE Lead Pipeline — Environment Variables ───────────────────────────────
# Copy this file to .env and fill in your real values.
# NEVER commit .env to git.

# Gmail SMTP (port 465 SSL)
GMAIL_USER=your-gmail@gmail.com
GMAIL_PASSWORD=xxxx xxxx xxxx xxxx

# Sales rep — receives hot lead alerts (score > 70)
GMAIL_TO=salesrep@yourcompany.com

# HuggingFace token — only needed if Whisper model download fails
HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Base URL for session links — do not change for local dev
BASE_URL=http://localhost:8000
